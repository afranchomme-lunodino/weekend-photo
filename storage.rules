rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos : upload libre dans /photos/, lecture libre
    match /photos/{teamId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024  // max 10 MB après compression
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
